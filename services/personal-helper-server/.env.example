# Personal Helper Server — 环境变量配置

# 服务端口（默认 3000）
PORT=3000

# 数据存储目录（默认 ~/.helper）
HELPER_DATA_DIR=/path/to/data/dir

# API Token（必填，否则会自动生成）
# 所有 REST 请求（除 /api/health 外）需要携带：
#   Authorization: Bearer <token>
API_TOKEN=your-secure-token-here

# Fi-Pool-Manager 地址（数据源，替代旧的 dsa-server）
# 默认端口 3721（与 Fi-PM 的 api/index.ts 中 API_PORT 一致）
FI_POOL_MANAGER_URL=http://localhost:3721
